---
import type { CollectionEntry } from 'astro:content';
interface Props { post: CollectionEntry<'posts'>; }
const { post } = Astro.props;
const { title, description, pubDate, image } = post.data;
const slug = post.slug;
const formattedDate = pubDate?.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<article class="border-b border-dark-700 pb-8">
  {image && (
    <a href={`/blog/${slug}/`} class="block rounded-xl overflow-hidden mb-4">
      <img src={image} alt={title} class="w-full h-48 object-cover hover:scale-105 transition-transform" />
    </a>
  )}
  <div>
    <time datetime={pubDate.toISOString()} class="text-white/50 text-sm">{formattedDate}</time>
    <h2 class="mt-2">
      <a href={`/blog/${slug}/`} class="font-display text-xl text-white hover:text-accent transition-colors">{title}</a>
    </h2>
    {description && <p class="text-white/60 mt-2">{description}</p>}
    <a href={`/blog/${slug}/`} class="inline-block mt-3 text-accent hover:underline text-sm">Ler mais →</a>
  </div>
</article>
