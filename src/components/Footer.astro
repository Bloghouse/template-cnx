---
import { siteConfig } from '../config';
const currentYear = new Date().getFullYear();
const navSecondary = (siteConfig as any).navSecondary || [];
---

<footer class="py-12 px-6 border-t border-[var(--color-border)]">
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <p class="text-white/50 text-sm">© {currentYear} {siteConfig.name}. Todos os direitos reservados.</p>
      <nav class="flex flex-wrap gap-4 md:gap-6" aria-label="Rodapé">
        {siteConfig.nav.map((item) => (
          <a href={item.href} class="text-white/50 hover:text-white text-sm transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center">{item.label}</a>
        ))}
        {navSecondary.map((item: any) => (
          <a href={item.href} class="text-white/40 hover:text-white text-sm transition-colors min-h-[44px] min-w-[44px] flex items-center justify-center">{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
